# Projeto Confeitaria - Environment Variables Example

PROJECT_NAME=Projeto confeitaria

# GitHub
GITHUB_PERSONAL_ACCESS_TOKEN=

# Stitch
STITCH_API_KEY=

# Vercel
VERCEL_API_TOKEN=

# Supabase
SUPABASE_ACCESS_TOKEN=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_KEY=
JWT_SECRET=

# Context7 (for documentation and search)
CONTEXT7_API_KEY=

# Ports
FRONTEND_PORT=3000
BACKEND_PORT=9090

# Database (PostgreSQL via Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=confeitaria
DATABASE_URL=postgresql://postgres:postgres@db:5432/confeitaria
